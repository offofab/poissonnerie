# Base de données PostgreSQL (Railway)
DATABASE_URL="postgresql://user:password@host:port/database"

# NextAuth — générer avec: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://your-app.up.railway.app"

# Web Push VAPID — générer avec:
#   node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:contact@example.com"

# Port (Railway le définit automatiquement)
# PORT=3000
